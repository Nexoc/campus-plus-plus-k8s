# Database secrets example
# Copy to a real env file outside git and fill with real values.

DB_USERNAME=replace-with-real-db-username
DB_PASSWORD=replace-with-real-db-password
EOFmkdir -p deploy/templates/config

cat > deploy/templates/config/app-config.env.example <<'EOF'
# Shared non-secret application config example
# Copy outside git and adjust per environment.

BACKEND_PROFILE=dev
AUTH_PROFILE=dev

DB_HOST=postgres
DB_PORT=5432
DB_NAME=campus

INGRESS_HOST=campus.local
INGRESS_CLASS_NAME=nginx
